PORT=10000
NODE_ENV=production

# MongoDB Atlas (required for Render - use Atlas connection string)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ad_agency?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Nodemailer (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME=AdAgency Portal

# Frontend (deployed URL — no trailing slash)
CLIENT_URL=https://your-frontend.onrender.com
FRONTEND_URL=https://your-frontend.onrender.com

# Google OAuth (update callback URL in Google Console to production domain)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SESSION_SECRET=your_random_session_secret

# AI APIs
GEMINI_API_KEY=your_gemini_api_key
